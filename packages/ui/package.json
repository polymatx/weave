{
  "name": "@polymatx/weave-ui",
  "version": "0.0.1",
  "description": "Local trace UI for @polymatx/weave",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "weave-ui": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "vite build",
    "build:server": "tsup",
    "dev": "concurrently \"vite\" \"tsup --watch\"",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "author": "polymatx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polymatx/weave.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/polymatx/weave",
  "bugs": "https://github.com/polymatx/weave/issues",
  "keywords": ["ai", "agent", "llm", "mcp", "observability", "tracing", "weave"],
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@polymatx/weave": "workspace:*",
    "hono": "^4.12.21"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.5"
  }
}
