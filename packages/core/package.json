  },
  "homepage": "https://github.com/polymatx/weave",
  "bugs": "https://github.com/polymatx/weave/issues",
  "dependencies": {
    "ai": "^6.0.185",
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "better-sqlite3": "^11.7.0",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  }
