{
  "name": "@polymatx/weave",
  "version": "0.0.1",
  "description": "TypeScript-native agent orchestrator. MCP-native. Observability built-in.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
