{
  "name": "@polymatx/weave",
  "version": "0.1.0",
  "description": "TypeScript-native agent orchestrator. MCP-native. Observability built-in.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ai", "agent", "orchestrator", "llm", "mcp", "typescript"],
  "license": "MIT",
  "author": "polymatx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polymatx/weave.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/polymatx/weave",
  "bugs": "https://github.com/polymatx/weave/issues",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "nanoid": "^5.0.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": { "optional": true },
    "@ai-sdk/openai": { "optional": true }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "ai": "^6.0.191",
    "@ai-sdk/anthropic": "^3.0.79"
  }
