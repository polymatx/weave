{
  "name": "weave-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "TypeScript-native agent orchestrator. MCP-native. Observability built-in.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "dev": "pnpm -r --parallel --filter='./packages/*' dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.17.0",
    "playwright": "^1.60.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.2"
}
